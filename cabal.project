packages:
  atelier-prelude
  atelier-core
  atelier-db
  atelier-testing
  tricorder

tests: True

-- Keep local/dev builds fast. The published .cabal files build optimized for
-- consumers; -O0 is a dev-only choice and so lives here, not in package.yaml.
package atelier-core
  optimization: False
package atelier-db
  optimization: False
package atelier-testing
  optimization: False

constraints:
  -- See https://github.com/circuithub/rel8/issues/402
  -- This effectively means that `atelier-db` (and by extension
  -- `atelier-testing`, since it depends on `atelier-db`) are broken.
  semialign < 1.4
